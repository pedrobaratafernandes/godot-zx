[gd_scene format=3 uid="uid://menuoverlay"]

[ext_resource type="Script" path="res://Scripts/GameMenu/GameMenu.gd" id="1_script"]

[node name="GameMenu" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_script")

[node name="Dimmer" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.470588)

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="Center"]
custom_minimum_size = Vector2(300, 250)
layout_mode = 2

[node name="Margin" type="MarginContainer" parent="Center/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="Content" type="VBoxContainer" parent="Center/Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Center/Panel/Margin/Content"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "MENU"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.6, 0.6, 1)
theme_override_font_sizes/font_size = 14
text = "Machine: 48K | Game: None"
horizontal_alignment = 1
autowrap_mode = 3

[node name="HSeparator" type="HSeparator" parent="Center/Panel/Margin/Content"]
layout_mode = 2

[node name="Spacer" type="Control" parent="Center/Panel/Margin/Content"]
custom_minimum_size = Vector2(0, 10)
layout_mode = 2

[node name="SaveButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../ResumeButton")
focus_neighbor_bottom = NodePath("../LoadButton")
text = "Save Progress"

[node name="LoadButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../SaveButton")
focus_neighbor_bottom = NodePath("../ResetButton")
text = "Load Progress"

[node name="ResetButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../LoadButton")
focus_neighbor_bottom = NodePath("../LauncherButton")
text = "Reset Emulator"

[node name="LauncherButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../ResetButton")
focus_neighbor_bottom = NodePath("../QuitButton")
text = "Return to Launcher"

[node name="QuitButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../LauncherButton")
focus_neighbor_bottom = NodePath("../FullscreenButton")
text = "Quit Game"

[node name="FullscreenButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../QuitButton")
focus_neighbor_bottom = NodePath("../ResumeButton")
text = "Toggle Fullscreen"

[node name="ResumeButton" type="Button" parent="Center/Panel/Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
focus_neighbor_top = NodePath("../FullscreenButton")
focus_neighbor_bottom = NodePath("../SaveButton")
theme_override_colors/font_color = Color(0.4, 1, 0.4, 1)
text = "Resume Emulation"
